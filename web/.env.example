# Copie para web/.env.local e preencha.
# Valores vazios = modo fallback local (quando o app suportar).
# Guia completo: docs/deploy-vercel-supabase.md

# --- Supabase (projeto NOVO — dados do CRM antigo podem ser descartados) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Servidor / cron apenas — nunca no cliente
# SUPABASE_SERVICE_ROLE_KEY=

# URL pública (produção: domínio Vercel)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Fastify (dev: porta 3001; produção: URL do deploy da API)
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Login local (dev / fallback) ---
# CRM_LOGIN_USER=
# CRM_LOGIN_PASSWORD=
# CRM_LOCAL_API_TOKEN=crm-execute-local-token

# --- Superadmin ---
# SUPERADMIN_SECRET=

# --- Vercel Cron ---
# CRON_SECRET=

# --- Sentry (opcional) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_DSN=

# --- WhatsApp (opcional) ---
# NEXT_PUBLIC_WHATSAPP_NOTIFICATIONS=true
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=
