{
  "name": "crm-execute-saas",
  "version": "1.0.0",
  "private": true,
  "description": "CRM Execute — monorepo SaaS",
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
