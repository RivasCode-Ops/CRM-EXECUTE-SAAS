# Copie para api/.env (não commitar)

# Supabase — substituir os três valores abaixo no painel: Settings → API
SUPABASE_URL=<COLAR_PROJECT_URL>
SUPABASE_ANON_KEY=<COLAR_ANON_PUBLIC>
SUPABASE_SERVICE_ROLE_KEY=<COLAR_SERVICE_ROLE>

# Redis (Upstash) — substituir URL e token da base Redis (REST)
REDIS_URL=<COLAR_UPSTASH_REDIS_REST_URL>
REDIS_TOKEN=<COLAR_UPSTASH_REDIS_REST_TOKEN>

# JWT — inventar/gerar uma string longa e aleatória (não vem de nenhum site)
JWT_SECRET=<COLAR_STRING_LONGA_ALEATORIA>

# API — igual ao modelo (desenvolvimento local)
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Produção: origens extras (vírgula), além de *.vercel.app e *.executeconstrurent.com.br
# CORS_ORIGINS=https://meu-app.vercel.app,https://crm.executeconstrurent.com.br

# Stripe (webhook POST /webhooks/stripe)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs (Dashboard Stripe → Products → Prices)
# STRIPE_PRICE_BASICO_MENSAL=price_...
# STRIPE_PRICE_BASICO_ANUAL=price_...
# STRIPE_PRICE_PRO_MENSAL=price_...
# STRIPE_PRICE_PRO_ANUAL=price_...
# STRIPE_PRICE_ENTERPRISE_MENSAL=price_...
# STRIPE_PRICE_ENTERPRISE_ANUAL=price_...